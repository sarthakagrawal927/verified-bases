---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Turnstile site key — set via Cloudflare Pages env (PUBLIC_TURNSTILE_SITE_KEY).
// Falls back to Cloudflare's test sitekey for local dev so the widget always renders.
const turnstileKey =
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA';
---

<BaseLayout
  title="Collab"
  description="Built something useful with AI? Tell me about it. I might list it alongside my own verified Bases — or just trade notes."
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 grid-bg opacity-50" aria-hidden="true"></div>
    <div class="relative container-page pt-16 pb-10 md:pt-24">
      <p class="kicker">Collab</p>
      <h1 class="mt-3 text-[2rem] font-semibold leading-[1.05] tracking-[-0.02em] text-fg sm:text-5xl text-balance">
        Built something useful?
        <span class="block text-accent">Tell me about it.</span>
      </h1>
      <p class="mt-5 max-w-2xl text-[16px] text-muted leading-relaxed text-pretty">
        Right now, every Base on this site is built and sold by me.
        If you've shipped something small and useful — a Mac app, a website starter,
        an internal tool — and you want it listed alongside mine, send it over.
        Or just send it because you want a second pair of eyes. I read every one.
      </p>
      <p class="mt-3 text-sm text-faint">
        No promises about listing. No exclusivity. Real reply within 7 days.
      </p>
    </div>
  </section>

  <section class="container-page py-12">
    <form
      id="submit-base-form"
      method="post"
      action="/api/submit"
      class="grid gap-8 md:grid-cols-[1.2fr,1fr]"
    >
      <div class="space-y-6">
        <div class="panel p-6 md:p-7">
          <p class="kicker">What you built</p>
          <div class="mt-5 grid gap-5">
            <label class="grid gap-2">
              <span class="field-label">Title</span>
              <input
                type="text" name="title" required maxlength="80"
                placeholder="e.g. Local Invoice Generator"
                class="field"
              />
            </label>

            <label class="grid gap-2">
              <span class="field-label">One-liner</span>
              <input
                type="text" name="one_liner" required maxlength="140"
                placeholder="One sentence describing what it does."
                class="field"
              />
            </label>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="grid gap-2">
                <span class="field-label">Category</span>
                <select name="category" required class="field">
                  <option value="">Pick one…</option>
                  <option value="mac-app">Mac app</option>
                  <option value="website">Website</option>
                  <option value="internal-tool">Internal tool</option>
                  <option value="creator-tool">Creator tool</option>
                  <option value="mobile-prototype">Mobile prototype</option>
                </select>
              </label>

              <label class="grid gap-2">
                <span class="field-label">Suggested price (USD)</span>
                <input
                  type="number" min="0" max="999" step="1" name="price" required
                  placeholder="e.g. 49"
                  class="field"
                />
              </label>
            </div>

            <label class="grid gap-2">
              <span class="field-label">GitHub repo or demo URL</span>
              <input
                type="url" name="repo_or_demo" required
                placeholder="https://github.com/… or https://demo.example.com"
                class="field"
              />
            </label>

            <label class="grid gap-2">
              <span class="field-label">Tech stack</span>
              <input
                type="text" name="stack" required
                placeholder="e.g. Astro, React, Tailwind v4, Supabase, Stripe, Cloudflare"
                class="field"
              />
            </label>
          </div>
        </div>

        <div class="panel p-6 md:p-7">
          <p class="kicker">Honesty fields</p>
          <p class="mt-1 text-xs text-faint">All required — these are the bits that matter most.</p>

          <div class="mt-5 grid gap-5">
            <label class="grid gap-2">
              <span class="field-label">What it does NOT do</span>
              <textarea
                name="does_not_do" required rows="3"
                placeholder="One per line. Be specific."
                class="field resize-y"
              ></textarea>
            </label>

            <label class="grid gap-2">
              <span class="field-label">Known limitations</span>
              <textarea
                name="limitations" required rows="3"
                placeholder="Tested up to N users, no mobile app, requires X account, etc."
                class="field resize-y"
              ></textarea>
            </label>

            <label class="grid gap-2">
              <span class="field-label">What AI usually gets wrong</span>
              <textarea
                name="ai_gets_wrong" rows="3"
                placeholder="The non-obvious bugs you hit. (Useful even if I don't list it.)"
                class="field resize-y"
              ></textarea>
            </label>
          </div>
        </div>

        <div class="cf-turnstile" data-sitekey={turnstileKey} data-theme="dark"></div>

        <div class="flex flex-wrap items-center gap-3">
          <button type="submit" class="btn btn-primary">
            Send it over →
          </button>
          <span class="text-xs text-faint">Real reply within 7 days.</span>
        </div>
      </div>

      <aside class="space-y-4">
        <div class="panel p-6">
          <p class="kicker">You</p>
          <div class="mt-4 grid gap-4">
            <label class="grid gap-2">
              <span class="field-label">Name</span>
              <input type="text" name="name" required class="field" />
            </label>
            <label class="grid gap-2">
              <span class="field-label">Email</span>
              <input type="email" name="email" required class="field" />
            </label>
            <label class="grid gap-2">
              <span class="field-label">GitHub / X handle</span>
              <input type="text" name="handle" placeholder="@yourhandle" class="field" />
            </label>
          </div>
        </div>

        <div class="panel-2 p-6 text-sm text-muted leading-relaxed text-pretty">
          <p class="kicker mb-3">What happens next</p>
          <ol class="space-y-2.5 list-decimal pl-5 marker:text-accent">
            <li>I read it within 7 days.</li>
            <li>If it's a fit, we polish the listing together.</li>
            <li>I record / verify the preview.</li>
            <li>You set tiers; we set up payouts.</li>
            <li>You keep 70–80% of every sale.</li>
          </ol>
          <p class="mt-4 pt-4 border-t border-line text-xs text-faint">
            If it's not a fit but it's interesting, I'll still reply with notes.
          </p>
        </div>
      </aside>
    </form>

    <div
      id="submit-result"
      class="mt-8 hidden panel-2 p-5 text-sm"
      role="status"
      aria-live="polite"
    ></div>
  </section>

  <script
    is:inline
    defer
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
  ></script>

  <script is:inline>
    (() => {
      const form = document.getElementById('submit-base-form');
      const result = document.getElementById('submit-result');
      if (!(form instanceof HTMLFormElement) || !result) return;

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        result.classList.remove('hidden');
        result.textContent = 'Sending…';
        result.style.color = 'var(--color-muted)';

        const data = Object.fromEntries(new FormData(form).entries());
        if (data.price) data.price = Number(data.price);
        // Turnstile injects "cf-turnstile-response" into the form. Forward it
        // to the BE as turnstile_token so the JSON parser sees a clean field.
        if (data['cf-turnstile-response']) {
          data.turnstile_token = data['cf-turnstile-response'];
          delete data['cf-turnstile-response'];
        }

        try {
          const res = await fetch('/api/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          if (res.ok) {
            result.textContent = 'Sent. I reply within 7 days.';
            result.style.color = 'var(--color-verified)';
            form.reset();
            // Re-render the Turnstile widget so a follow-up submit works.
            if (window.turnstile) window.turnstile.reset();
            return;
          }
          const body = await res.json().catch(() => ({}));
          result.textContent =
            'Could not send: ' + (body.error || res.statusText || 'unknown_error');
          result.style.color = 'var(--color-warn)';
        } catch (err) {
          result.textContent =
            'Could not send. Email sarthakagrawal927@gmail.com directly.';
          result.style.color = 'var(--color-warn)';
        }
      });
    })();
  </script>
</BaseLayout>
