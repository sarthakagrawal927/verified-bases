---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TierCard from '@/components/astro/TierCard.astro';
import TierModal from '@/components/astro/TierModal.astro';
import { BASES, CATEGORY_META, BADGE_META } from '@/data/bases';

export function getStaticPaths() {
  return BASES.map((b) => ({ params: { slug: b.slug }, props: { base: b } }));
}

const { base } = Astro.props;

// Globals consumed by TierModal — kept small to avoid bloating HTML.
const tiersByKey = Object.fromEntries(
  base.tiers.map(t => [t.key, { key: t.key, label: t.label, price: t.price }])
);
const modalGlobals = JSON.stringify({
  slug: base.slug,
  title: base.title,
  previewUrl: base.previewUrl ?? null,
  tiers: tiersByKey,
});

const tierForDisplay = (k: string) => base.tiers.find((t) => t.key === k);
const ownTier = tierForDisplay('own');

const diffDot = (d: 'easy' | 'medium' | 'hard') =>
  d === 'easy' ? 'bg-verified' : d === 'medium' ? 'bg-accent' : 'bg-[var(--color-danger)]';

const diffLabel = (d: 'easy' | 'medium' | 'hard') =>
  d === 'easy' ? 'Easy' : d === 'medium' ? 'Medium' : 'Hard';

const verifiedDate = new Date(base.lastVerified).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BaseLayout
  title={base.title}
  description={base.oneLiner}
  type="article"
>
  <!-- ─────────────────────────── HERO ────────────────────────── -->
  <section class="relative">
    <div class="absolute inset-0 grid-bg opacity-40" aria-hidden="true"></div>
    <div class="relative container-page pt-12 pb-10 md:pt-16">
      <a href="/bases" class="font-mono text-xs text-muted hover:text-fg">← All Bases</a>

      <div class="mt-6 grid gap-10 lg:grid-cols-[1.4fr,1fr]">
        <div>
          <div class="flex flex-wrap items-center gap-2.5">
            <span class="kicker">{CATEGORY_META[base.category].label}</span>
            <span class="text-faint">·</span>
            <span class="font-mono text-xs text-muted">Last verified {verifiedDate}</span>
          </div>

          <h1 class="mt-4 text-4xl font-semibold leading-[1.05] tracking-[-0.02em] text-fg text-balance sm:text-5xl">
            {base.title}
          </h1>
          <p class="mt-4 max-w-2xl text-lg text-muted leading-relaxed text-pretty">
            {base.oneLiner}
          </p>

          <div class="mt-6 flex flex-wrap gap-1.5">
            {base.badges.map((b) => (
              <span
                class:list={[
                  'badge',
                  BADGE_META[b].tone === 'verified' && 'badge-verified',
                  BADGE_META[b].tone === 'accent'   && 'badge-accent',
                ]}
              >
                {BADGE_META[b].tone === 'verified' && '✓'}
                {BADGE_META[b].label}
              </span>
            ))}
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            {base.previewUrl && (
              <a href={base.previewUrl} target="_blank" rel="noopener" class="btn btn-primary">
                Try live preview <span aria-hidden="true">↗</span>
              </a>
            )}
            <a href="#tiers" class="btn btn-ghost">
              {ownTier ? `Own source — ${ownTier.price}` : 'See tiers'}
            </a>
            <a href="#alternatives" class="btn btn-naked text-sm">
              Should you prompt this yourself? →
            </a>
          </div>
        </div>

        <!-- Preview card — live iframe if available, else a styled placeholder. -->
        <aside class="panel relative h-full min-h-[280px] overflow-hidden">
          <div class="absolute inset-0 grid-bg opacity-40"></div>
          <div class="relative flex h-full flex-col">
            <div class="flex items-center gap-1.5 border-b border-line bg-panel-2 px-4 py-2.5">
              <span class="h-2 w-2 rounded-full bg-[var(--color-danger)]"></span>
              <span class="h-2 w-2 rounded-full bg-warn"></span>
              <span class="h-2 w-2 rounded-full bg-verified"></span>
              <span class="ml-3 font-mono text-[0.7rem] text-faint truncate">
                {base.previewUrl ?? `${base.slug}.app`}
              </span>
            </div>
            <div class="flex flex-1 items-center justify-center p-6">
              {base.previewUrl ? (
                <div class="text-center">
                  <div class="kicker mb-2">Live preview</div>
                  <a href={base.previewUrl} target="_blank" rel="noopener" class="link text-fg">
                    {base.previewUrl.replace(/^https?:\/\//, '')}
                  </a>
                </div>
              ) : (
                <div class="text-center">
                  <div class="kicker-muted mb-2">Demo</div>
                  <p class="text-sm text-muted">Demo video & screenshots available on request.</p>
                </div>
              )}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ─────────────────────── DOES / DOESN'T ──────────────────── -->
  <section class="container-page py-12">
    <div class="grid gap-6 md:grid-cols-2">
      <div class="panel p-6">
        <p class="kicker">What this Base does</p>
        <ul class="mt-4 space-y-2.5 text-[15px] text-muted">
          {base.does.map((line) => (
            <li class="flex items-start gap-3">
              <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--color-verified);"></span>
              <span class="text-pretty">{line}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="panel p-6">
        <p class="kicker" style="color: var(--color-warn);">What it does NOT do</p>
        <ul class="mt-4 space-y-2.5 text-[15px] text-muted">
          {base.doesNotDo.map((line) => (
            <li class="flex items-start gap-3">
              <span class="mt-2 inline-block h-px w-2.5 shrink-0" style="background: var(--color-warn);"></span>
              <span class="text-pretty">{line}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ───────────────────── DIY WITH AI ESTIMATE ──────────────── -->
  <section class="container-page py-12">
    <header class="max-w-2xl">
      <p class="kicker">DIY with AI estimate</p>
      <h2 class="mt-3 text-2xl font-semibold text-fg sm:text-3xl text-balance">
        How hard would this be to vibe-code from scratch?
      </h2>
      <p class="mt-3 text-[15px] text-muted text-pretty">
        Honest. So you can decide whether to buy or prompt your own.
      </p>
    </header>

    <div class="mt-8 grid gap-4 md:grid-cols-[1.2fr,1fr]">
      <div class="panel p-6">
        <div class="grid grid-cols-3 gap-4 border-b border-line pb-5">
          {([
            ['Prompt', base.diy.prompt],
            ['Debug', base.diy.debug],
            ['Launch', base.diy.launch],
          ] as const).map(([label, d]) => (
            <div>
              <div class="kicker-muted">{label}</div>
              <div class="mt-2 flex items-center gap-2">
                <span class:list={['h-2 w-2 rounded-full', diffDot(d)]}></span>
                <span class="text-sm text-fg">{diffLabel(d)}</span>
              </div>
            </div>
          ))}
        </div>

        <div class="grid grid-cols-2 gap-4 pt-5">
          <div>
            <div class="kicker-muted">Self-build time</div>
            <div class="mt-1.5 text-base text-fg font-mono">{base.diy.selfBuildHours}</div>
          </div>
          <div>
            <div class="kicker-muted">Setup from Base</div>
            <div class="mt-1.5 text-base text-fg font-mono">{base.diy.setupFromBase}</div>
          </div>
        </div>
      </div>

      <div class="panel-2 p-6">
        <p class="kicker">What AI usually gets wrong</p>
        <ul class="mt-4 space-y-2.5 text-[15px] text-muted">
          {base.diy.aiOftenGetsWrong.map((line) => (
            <li class="flex items-start gap-3">
              <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
              <span class="text-pretty">{line}</span>
            </li>
          ))}
        </ul>
        <div class="mt-5 rounded-md border border-line bg-panel p-4 text-sm text-fg text-pretty">
          <span class="kicker">Why buy</span>
          <p class="mt-1.5">{base.diy.whyBuy}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────── ALTERNATIVES ──────────────────── -->
  <section id="alternatives" class="container-page py-12">
    <header class="max-w-2xl">
      <p class="kicker">Honest alternatives</p>
      <h2 class="mt-3 text-2xl font-semibold text-fg sm:text-3xl text-balance">
        Other ways to solve this problem.
      </h2>
    </header>

    <div class="mt-8 grid gap-3 md:grid-cols-2 lg:grid-cols-4">
      {[
        { t: 'Free alternatives',  d: base.alternatives.free },
        { t: 'Paid SaaS alternative', d: base.alternatives.paidSaas },
        { t: 'Prompt it yourself',   d: base.alternatives.promptYourself },
        { t: 'This Base is best if', d: base.alternatives.bestIf, accent: true },
      ].map((alt) => (
        <div class:list={['panel p-5', alt.accent && 'glow-accent']}>
          <p class:list={['kicker', !alt.accent && 'kicker-muted']}>{alt.t}</p>
          <p class="mt-3 text-sm text-muted leading-relaxed text-pretty">{alt.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ──────────────────────── TIERS / PRICING ───────────────── -->
  <section id="tiers" class="container-page py-12">
    <header class="max-w-2xl">
      <p class="kicker">Tiers</p>
      <h2 class="mt-3 text-2xl font-semibold text-fg sm:text-3xl text-balance">
        Pay for the outcome you want.
      </h2>
      <p class="mt-3 text-[15px] text-muted text-pretty">
        Preview is free. Tiers escalate from "I just want it" to "deploy it for me".
      </p>
    </header>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {base.tiers.map((tier) => (
        <TierCard tier={tier} primary={tier.key === 'own'} />
      ))}
    </div>
  </section>

  <!-- ──────────────────────── TECH STACK ────────────────────── -->
  <section class="container-page py-12">
    <div class="grid gap-6 md:grid-cols-2">
      <div class="panel p-6">
        <p class="kicker">Tech stack</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {base.techStack.map((t) => (
            <span class="chip">{t}</span>
          ))}
        </div>
      </div>

      <div class="panel p-6">
        <p class="kicker" style="color: var(--color-warn);">Known limitations</p>
        <ul class="mt-4 space-y-2.5 text-[15px] text-muted">
          {base.limitations.map((line) => (
            <li class="flex items-start gap-3">
              <span class="mt-2 inline-block h-px w-2.5 shrink-0" style="background: var(--color-warn);"></span>
              <span class="text-pretty">{line}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────── LICENSE ────────────────────── -->
  <section class="container-page py-12">
    <div class="panel-2 p-6 md:p-8">
      <div class="grid gap-6 md:grid-cols-[1fr,2fr]">
        <div>
          <p class="kicker">License</p>
          <h3 class="mt-3 text-xl font-semibold text-fg">You own your copy.</h3>
          <p class="mt-2 text-sm text-faint">Created by {base.creator.name}{base.creator.handle ? ` (@${base.creator.handle})` : ''}.</p>
        </div>
        <p class="text-[15px] text-muted text-pretty leading-relaxed">
          {base.license}
        </p>
      </div>
    </div>
  </section>

  <TierModal />
  <script is:inline set:html={`
    (() => {
      const g = ${modalGlobals};
      window.__BASE_SLUG__    = g.slug;
      window.__BASE_TITLE__   = g.title;
      window.__BASE_PREVIEW__ = g.previewUrl;
      window.__BASE_TIERS__   = g.tiers;
    })();
  `} />
</BaseLayout>
