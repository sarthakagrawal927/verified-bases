---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BaseCard from '@/components/astro/BaseCard.astro';
import { BASES, CATEGORY_META } from '@/data/bases';

const cats = (Object.keys(CATEGORY_META) as Array<keyof typeof CATEGORY_META>);
const allCounts = cats.map(c => ({
  key: c,
  label: CATEGORY_META[c].label,
  count: BASES.filter(b => b.category === c).length,
}));
---

<BaseLayout
  title="All Bases"
  description="Browse every verified software Base. Filter by Mac apps, websites, internal tools, or creator tools."
>
  <section class="container-page pt-14 pb-10 md:pt-20">
    <p class="kicker">Browse</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight text-fg sm:text-4xl text-balance">
      {BASES.length === 0
        ? 'No Bases shipped yet.'
        : `${BASES.length} verified Base${BASES.length === 1 ? '' : 's'}. Built by me.`}
    </h1>
    <p class="mt-3 max-w-2xl text-[15px] text-muted text-pretty leading-relaxed">
      {BASES.length === 0
        ? 'The first Base is in the oven. When it ships, it lands here with a live preview, source code, the DIY-with-AI estimate, honest alternatives, and tiered pricing.'
        : 'I shipped, tested, and maintain each one. Click any card for the full breakdown: live preview, what it does and doesn\'t, DIY-with-AI estimate, honest alternatives, and tiered pricing.'}
    </p>

    {BASES.length > 0 && (
      <!-- Filter pills — client-side filter via data-cat. -->
      <div class="mt-8 flex flex-wrap gap-2" role="tablist" aria-label="Filter by category">
        <button
          data-filter="all"
          class="chip is-active"
          aria-pressed="true"
          type="button"
          style="border-color: var(--color-accent-dim); color: var(--color-accent); background: color-mix(in srgb, var(--color-accent) 10%, var(--color-panel-2));"
        >
          All
          <span class="ml-1 text-faint">·</span>
          <span class="ml-1">{BASES.length}</span>
        </button>
        {allCounts.map(({ key, label, count }) => (
          <button
            data-filter={key}
            class="chip"
            aria-pressed="false"
            type="button"
          >
            {label}
            <span class="ml-1 text-faint">·</span>
            <span class="ml-1">{count}</span>
          </button>
        ))}
      </div>
    )}
  </section>

  <section class="container-page pb-24">
    {BASES.length === 0 ? (
      <div class="panel p-8 md:p-12">
        <p class="text-[15px] text-muted leading-relaxed text-pretty max-w-2xl">
          Want a heads-up when the first Base lands? Drop me a note via
          <a class="link text-accent" href="/collab">/collab</a> — or check back
          in a week or two. I won't list anything until I'd happily run it for someone else.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/trust" class="btn btn-primary">How I verify →</a>
          <a href="/collab" class="btn btn-ghost">Get in touch</a>
        </div>
      </div>
    ) : (
      <>
        <div id="grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {BASES.map((b) => <BaseCard base={b} />)}
        </div>
        <p id="empty" class="hidden py-12 text-center text-sm text-muted">
          Nothing in this category yet. Try another, or
          <a href="/collab" class="link text-accent">say hi</a>.
        </p>
      </>
    )}
  </section>

  <script is:inline>
    (() => {
      const grid = document.getElementById('grid');
      const empty = document.getElementById('empty');
      const buttons = document.querySelectorAll('[data-filter]');
      if (!grid || !buttons.length) return;

      const cards = Array.from(grid.querySelectorAll('[data-cat]'));

      const applyFilter = (filter) => {
        let shown = 0;
        cards.forEach((card) => {
          const visible = filter === 'all' || card.getAttribute('data-cat') === filter;
          card.style.display = visible ? '' : 'none';
          if (visible) shown++;
        });
        if (empty) empty.classList.toggle('hidden', shown > 0);

        buttons.forEach((b) => {
          const isActive = b.getAttribute('data-filter') === filter;
          b.setAttribute('aria-pressed', String(isActive));
          if (isActive) {
            b.style.borderColor = 'var(--color-accent-dim)';
            b.style.color = 'var(--color-accent)';
            b.style.background = 'color-mix(in srgb, var(--color-accent) 10%, var(--color-panel-2))';
          } else {
            b.style.borderColor = '';
            b.style.color = '';
            b.style.background = '';
          }
        });

        const url = new URL(window.location.href);
        if (filter === 'all') url.searchParams.delete('cat');
        else url.searchParams.set('cat', filter);
        history.replaceState(null, '', url.toString());
      };

      buttons.forEach((b) =>
        b.addEventListener('click', () => applyFilter(b.getAttribute('data-filter')))
      );

      const initial = new URL(window.location.href).searchParams.get('cat') || 'all';
      applyFilter(initial);
    })();
  </script>
</BaseLayout>
