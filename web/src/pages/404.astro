---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not found">
  <section class="container-page flex min-h-[60vh] flex-col items-center justify-center text-center">
    <p class="kicker">404</p>
    <h1 class="mt-3 text-4xl font-semibold text-fg sm:text-5xl">No Base at that path.</h1>
    <p class="mt-4 max-w-md text-[15px] text-muted text-pretty">
      The Base you're looking for has been moved, never listed, or failed re-verification.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/bases" class="btn btn-primary">Browse Bases →</a>
      <a href="/" class="btn btn-ghost">Home</a>
    </div>
  </section>
</BaseLayout>
