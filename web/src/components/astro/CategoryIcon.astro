---
import type { Category } from '@/data/bases';

interface Props {
  category: Category;
  size?: number;
}
const { category, size = 28 } = Astro.props;
---

{category === 'mac-app' && (
  <svg viewBox="0 0 32 32" width={size} height={size} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3.5" y="6" width="25" height="18" rx="2.5" />
    <line x1="3.5" y1="11" x2="28.5" y2="11" />
    <circle cx="6.5" cy="8.5" r="0.9" fill="currentColor" />
    <circle cx="9.5" cy="8.5" r="0.9" fill="currentColor" />
    <circle cx="12.5" cy="8.5" r="0.9" fill="currentColor" />
    <path d="M11 24v2.5h10V24" />
    <path d="M8.5 26.5h15" />
    <path d="M8 16h6m-6 3h4" />
  </svg>
)}

{category === 'website' && (
  <svg viewBox="0 0 32 32" width={size} height={size} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3.5" y="5" width="25" height="22" rx="2" />
    <line x1="3.5" y1="10" x2="28.5" y2="10" />
    <circle cx="6.5" cy="7.5" r="0.7" fill="currentColor" />
    <circle cx="9" cy="7.5" r="0.7" fill="currentColor" />
    <rect x="14" y="6.5" width="11" height="2" rx="1" />
    <path d="M8 14h16m-16 4h12m-12 4h10" />
    <path d="M22 22l3 3-1.5.5L23 27" />
  </svg>
)}

{category === 'internal-tool' && (
  <svg viewBox="0 0 32 32" width={size} height={size} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3.5" y="5" width="25" height="22" rx="2" />
    <rect x="6"   y="9"  width="9"  height="7" rx="1.2" />
    <rect x="17"  y="9"  width="9"  height="4" rx="1.2" />
    <rect x="17"  y="15" width="9"  height="8" rx="1.2" />
    <rect x="6"   y="18" width="9"  height="5" rx="1.2" />
    <path d="M19 18l3 4 4-5" />
  </svg>
)}

{category === 'creator-tool' && (
  <svg viewBox="0 0 32 32" width={size} height={size} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M6 6l20 7-7 3-2 7-11-17z" />
    <circle cx="19" cy="16" r="1.5" fill="currentColor" />
    <path d="M22 6l1.5 2.5M27 9l-2.5 1M25 14l1.5 2" />
  </svg>
)}

{category === 'mobile-prototype' && (
  <svg viewBox="0 0 32 32" width={size} height={size} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="10" y="3.5" width="12" height="25" rx="2.5" />
    <line x1="10" y1="7.5" x2="22" y2="7.5" />
    <line x1="10" y1="24.5" x2="22" y2="24.5" />
    <circle cx="16" cy="26.5" r="0.9" fill="currentColor" />
    <path d="M13 11h6m-6 3h4m-4 3h6m-6 3h3" />
  </svg>
)}
