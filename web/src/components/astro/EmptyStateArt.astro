---
/**
 * Empty-state illustration — "first Base in the oven."
 *
 * A constructive, hopeful visual: a panel mid-construction, with the
 * verification stamp half-applied. Implies "soon" without feeling unfinished.
 */
---

<figure class="empty-art" aria-hidden="true">
  <svg viewBox="0 0 520 280" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="emptyPanel" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"  stop-color="#16181c" />
        <stop offset="100%" stop-color="#0f1012" />
      </linearGradient>
      <pattern id="emptyDots" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="1" fill="#22252b" />
      </pattern>
    </defs>

    <!-- Backdrop dot field -->
    <rect x="0" y="0" width="520" height="280" fill="url(#emptyDots)" opacity="0.4" />

    <!-- Centre panel, slightly tilted -->
    <g transform="translate(140,46) rotate(-2)" class="empty-panel">
      <rect x="0" y="0" width="260" height="180" rx="12"
            fill="url(#emptyPanel)" stroke="#2c2f35" />
      <!-- Chrome -->
      <rect x="0" y="0" width="260" height="26" rx="12" fill="#141518" />
      <rect x="0" y="18" width="260" height="8" fill="#141518" />
      <circle cx="14" cy="13" r="3.5" fill="#3a3d44" />
      <circle cx="26" cy="13" r="3.5" fill="#3a3d44" />
      <circle cx="38" cy="13" r="3.5" fill="#3a3d44" />

      <!-- Skeleton lines (Bases-coming placeholders) -->
      <rect x="20" y="48" width="180" height="12" rx="3" fill="#1f2126" />
      <rect x="20" y="68" width="120" height="8" rx="3" fill="#1d1f23" />

      <rect x="20" y="98"  width="220" height="20" rx="6" fill="#141518" stroke="#1f2126" />
      <rect x="20" y="124" width="220" height="20" rx="6" fill="#141518" stroke="#1f2126" />
      <rect x="20" y="150" width="100" height="20" rx="6" fill="#141518" stroke="#1f2126" />

      <!-- "Building…" indicator -->
      <g transform="translate(20,150)" class="empty-progress">
        <rect x="0" y="0" width="100" height="20" rx="6" fill="#141518" stroke="#1f2126" />
        <rect x="0" y="0" width="38" height="20" rx="6" fill="url(#emptyPanel)" stroke="#7a5a1f" />
        <text x="50" y="13" text-anchor="middle"
              font-family="ui-monospace,'SF Mono',monospace"
              font-size="9" letter-spacing="1.4" fill="#f0b54a">BUILDING</text>
      </g>
    </g>

    <!-- Half-applied VERIFIED stamp, drifting in -->
    <g transform="translate(330,38) rotate(-8)" class="empty-stamp">
      <rect x="0" y="0" width="84" height="26" rx="4"
            fill="none" stroke="#f0b54a" stroke-width="1.8" stroke-dasharray="60 28" />
      <text x="42" y="18" text-anchor="middle"
            font-family="ui-monospace,'SF Mono',monospace" font-size="11"
            letter-spacing="2.4" fill="#f0b54a">✓ VERIFIED</text>
    </g>

    <!-- Subtle floating spec sheet -->
    <g transform="translate(58,180)" class="empty-spec">
      <rect x="0" y="0" width="100" height="64" rx="6" fill="#0f1012" stroke="#2c2f35" />
      <text x="10" y="16" font-family="ui-monospace,'SF Mono',monospace" font-size="8"
            letter-spacing="1.4" fill="#787d88">SPEC</text>
      <line x1="10" y1="26" x2="84" y2="26" stroke="#1f2126" />
      <line x1="10" y1="34" x2="70" y2="34" stroke="#1f2126" />
      <line x1="10" y1="42" x2="78" y2="42" stroke="#1f2126" />
      <line x1="10" y1="50" x2="56" y2="50" stroke="#1f2126" />
    </g>

    <!-- Orbit dot indicating motion / progress -->
    <g transform="translate(420,160)" class="empty-orbit">
      <circle cx="0" cy="0" r="30" fill="none" stroke="#1f2126" stroke-dasharray="2 4" />
      <circle cx="30" cy="0" r="3" fill="#f0b54a" />
    </g>
  </svg>
</figure>

<style>
  .empty-art {
    margin: 0;
    width: 100%;
    max-width: 520px;
  }
  .empty-art svg { width: 100%; height: auto; display: block; }

  .empty-stamp {
    transform-origin: 42px 13px;
    animation: pulse-soft 3s ease-in-out infinite;
  }
  .empty-orbit {
    transform-box: fill-box;
    transform-origin: center;
    animation: orbit 6s linear infinite;
  }
  .empty-spec {
    animation: rise 0.8s var(--ease-out-expo) both;
    animation-delay: 0.2s;
  }
  .empty-panel {
    transform-origin: 130px 90px;
    animation: rise 0.9s var(--ease-out-expo) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .empty-art * { animation: none !important; opacity: 1 !important; }
  }
</style>
