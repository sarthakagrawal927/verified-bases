  <div class="container-page py-12 md:py-16">
    <div class="grid gap-10 md:grid-cols-[1.4fr,1fr,1fr,1fr]">
      <div>
        <div class="flex items-center gap-2.5">
          <span
            class="grid h-8 w-8 place-items-center rounded-md border border-accent-dim text-accent font-mono text-sm"
            style="background: color-mix(in srgb, var(--color-accent) 6%, var(--color-panel));"
          >◆</span>
          <span class="font-mono text-[0.82rem] tracking-[0.06em] text-fg">
            verified<span class="text-muted">/</span>bases
          </span>
