          <li><a class="link" href="/trust">How I verify</a></li>
          <li><a class="link" href="/collab">Collab</a></li>
          <li><a class="link" href="/about">About</a></li>
          <li><a class="link" href="/privacy">Privacy</a></li>
          <li><a class="link" href="/terms">Terms</a></li>
          <li><a class="link" href="/refund">Refunds</a></li>
        </ul>
      </div>

      <div>
        <p class="kicker-muted">Built in the open</p>
