# Copy to web/.env (and to your Cloudflare Pages project env vars) and fill.
# Only PUBLIC_* variables are exposed to the client bundle — keep secrets out.

# Cloudflare Web Analytics token (Site → Analytics → Web Analytics → JS snippet).
# Optional. When unset, the beacon script is omitted entirely.
PUBLIC_CF_BEACON=""

# Cloudflare Turnstile site key (paired with TURNSTILE_SECRET on the API).
# Test key "1x00000000000000000000AA" always passes — use locally.
PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"

# Canonical site origin — used in OG meta canonical URL.
# Override per-environment (preview deployments will pick up Astro.site at build).
PUBLIC_SITE_ORIGIN="https://bases.sarthakagrawal.dev"
